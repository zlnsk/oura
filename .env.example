# Oura Ring (https://cloud.ouraring.com/personal-access-tokens)
OURA_TOKEN=your_oura_personal_access_token

# Google OAuth (https://console.cloud.google.com/) - Optional
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_secret

# OpenRouter (https://openrouter.ai) - Optional, for AI summaries
OPENROUTER_API_KEY=your_openrouter_api_key

# Withings (https://developer.withings.com) - Optional, for weight data
WITHINGS_CLIENT_ID=your_withings_client_id
WITHINGS_CLIENT_SECRET=your_withings_client_secret
