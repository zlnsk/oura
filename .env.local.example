# Google OAuth (for Gmail login — open to all Google accounts)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth
NEXTAUTH_URL=http://localhost:3000/Oura
NEXTAUTH_SECRET=your-nextauth-secret-generate-with-openssl-rand-base64-32

# Anthropic API Key (for AI summaries — optional, enables AI health insights)
# If not set, the AI summary feature will be hidden
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: limit AI summaries per user per day (default: 20)
AI_SUMMARY_DAILY_LIMIT=20

# Optional: override the Claude model used for AI summaries
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Withings OAuth (optional — for weight/body composition data)
# Create an app at https://developer.withings.com/dashboard/
# Set callback URL to: https://your-domain.com/Oura/api/withings/callback
WITHINGS_CLIENT_ID=your-withings-client-id
WITHINGS_CLIENT_SECRET=your-withings-client-secret

# Optional: restrict access to specific email addresses (comma-separated)
# If not set, all Google accounts are allowed (suitable for personal deployments)
# ALLOWED_EMAILS=user@example.com,another@example.com
